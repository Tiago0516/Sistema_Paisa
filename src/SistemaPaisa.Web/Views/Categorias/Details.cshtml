@model SistemaPaisa.Application.DTOs.CategoriaDto

@{
    ViewData["Title"] = "Detalle categoria";
}

<h1 class="h3 mb-3">Detalle categoria</h1>

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Nombre</dd>

    <dt class="col-sm-2">Descripcion</dt>
    <dd class="col-sm-10">@Model.Descripcion</dd>

    <dt class="col-sm-2">Activa</dt>
    <dd class="col-sm-10">@(Model.Activa ? "Si" : "No")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
<a asp-action="Index" class="btn btn-secondary">Volver</a>
