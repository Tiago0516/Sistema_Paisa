@model SistemaPaisa.Application.Features.AppActions.Commands.CreateAppAction.CreateAppActionCommand
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    var modules = ViewBag.Modules as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
}

<form asp-controller="AppActions"
      asp-action="Create"
      method="post"
      class="module-modal-form"
      data-modal-form="true">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Nombre</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Code" class="form-label">Código</label>
        <input asp-for="Code" class="form-control" />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ModuleId" class="form-label">Módulo</label>
        <select asp-for="ModuleId" asp-items="modules" class="form-select">
            <option value="">Seleccione un módulo</option>
        </select>
        <span asp-validation-for="ModuleId" class="text-danger"></span>
    </div>
    <div class="d-flex justify-content-end gap-2 pt-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-module-create">Guardar</button>
    </div>
</form>
