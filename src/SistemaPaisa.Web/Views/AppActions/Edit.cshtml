@model SistemaPaisa.Application.Features.AppActions.Commands.UpdateAppAction.UpdateAppActionCommand
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Editar acción";
    var modules = ViewBag.Modules as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
}

<h1 class="h3 mb-3">Editar acción</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Nombre</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Code" class="form-label">Código</label>
        <input asp-for="Code" class="form-control" />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ModuleId" class="form-label">Módulo</label>
        <select asp-for="ModuleId" asp-items="modules" class="form-select">
            <option value="">Seleccione un módulo</option>
        </select>
        <span asp-validation-for="ModuleId" class="text-danger"></span>
    </div>
    <div class="mb-3 form-check">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Activo</label>
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a href="@ModuleRoutes.GetWorkspacePath("ACTIONS")" class="btn btn-secondary">Volver</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
