@model SistemaPaisa.Application.DTOs.ActionDto

@{
    ViewData["Title"] = "Detalles de la acción";
}

<h1 class="h3 mb-3">Detalles de la acción</h1>

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Código</dt>
    <dd class="col-sm-10">@Model.Code</dd>
    <dt class="col-sm-2">Módulo</dt>
    <dd class="col-sm-10">@Model.ModuleName</dd>
    <dt class="col-sm-2">Activo</dt>
    <dd class="col-sm-10">@(Model.IsActive ? "Sí" : "No")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
<a asp-controller="Home" asp-action="Index" asp-route-module="ACTIONS" class="btn btn-secondary">Volver</a>
