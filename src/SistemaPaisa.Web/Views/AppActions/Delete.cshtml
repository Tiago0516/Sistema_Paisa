@model SistemaPaisa.Application.DTOs.ActionDto

@{
    ViewData["Title"] = "Eliminar acción";
}

<h1 class="h3 mb-3 text-danger">Eliminar acción</h1>

<p>¿Está seguro de que desea eliminar esta acción?</p>

<dl class="row">
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Código</dt>
    <dd class="col-sm-10">@Model.Code</dd>
    <dt class="col-sm-2">Módulo</dt>
    <dd class="col-sm-10">@Model.ModuleName</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-controller="Home" asp-action="Index" asp-route-module="ACTIONS" class="btn btn-secondary">Cancelar</a>
</form>
