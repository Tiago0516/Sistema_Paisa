@{
    ViewData["Title"] = "Cambiar rol de usuario";
    var roles = ViewBag.Roles as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? [];
    var userId = (int)ViewBag.UserId;
}

<div class="content-card">
    <h1 class="h4 mb-4">Cambiar rol del usuario</h1>

    <form asp-action="EditRole" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="userId" value="@userId" />

        <div class="mb-3">
            <label class="form-label">Rol asignado</label>
            <select name="roleId" class="form-select">
                <option value="0">— Seleccionar rol —</option>
                @foreach (var role in roles)
                {
                    <option value="@role.Value">@role.Text</option>
                }
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Guardar</button>
        <a asp-controller="Home" asp-action="Index" asp-route-module="USERS" class="btn btn-secondary">Volver</a>
    </form>
</div>
