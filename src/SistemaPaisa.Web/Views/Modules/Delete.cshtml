@model SistemaPaisa.Application.DTOs.ModuleDto

@{
    ViewData["Title"] = "Eliminar módulo";
}

<h1 class="h3 mb-3 text-danger">Eliminar módulo</h1>

<p>¿Está seguro de que desea eliminar este módulo?</p>

<dl class="row">
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Descripción</dt>
    <dd class="col-sm-10">@Model.Description</dd>
    <dt class="col-sm-2">Código</dt>
    <dd class="col-sm-10">@Model.Code</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a href="@ModuleRoutes.GetWorkspacePath("MODULES")" class="btn btn-secondary">Cancelar</a>
</form>
