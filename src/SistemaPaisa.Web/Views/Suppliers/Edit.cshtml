@model SistemaPaisa.Application.Features.Suppliers.Commands.UpdateSupplier.UpdateSupplierCommand

@{
    ViewData["Title"] = "Editar proveedor";
    var apiUrl = $"/api/suppliers/{Model.Id}";
}

<h1 class="h3 mb-3">Editar proveedor</h1>

<div class="alert alert-danger d-none" data-api-load-error></div>

<form data-api-url="@apiUrl"
      data-api-method="PUT"
      data-api-load="@apiUrl"
      data-api-redirect="@ModuleRoutes.GetWorkspacePath("SUPPLIERS")">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span class="text-danger" data-api-error asp-validation-for="Name"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" type="email" />
        <span class="text-danger" data-api-error asp-validation-for="Email"></span>
    </div>
    <div class="mb-3 form-check">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a href="@ModuleRoutes.GetWorkspacePath("SUPPLIERS")" class="btn btn-secondary">Volver</a>
</form>
