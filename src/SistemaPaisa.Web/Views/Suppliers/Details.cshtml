@model SistemaPaisa.Application.DTOs.SupplierDto

@{
    ViewData["Title"] = "Detalle del proveedor";
}

<h1 class="h3 mb-3">Detalle del proveedor</h1>

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Correo</dt>
    <dd class="col-sm-10">@Model.Email</dd>
    <dt class="col-sm-2">Activo</dt>
    <dd class="col-sm-10">@(Model.IsActive ? "Sí" : "No")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
<a href="@ModuleRoutes.GetWorkspacePath("SUPPLIERS")" class="btn btn-secondary">Volver</a>
