@model int

@{
    ViewData["Title"] = "Detalle del proveedor";
    var apiUrl = $"/api/suppliers/{Model}";
}

<h1 class="h3 mb-3">Detalle del proveedor</h1>

<div class="alert alert-danger d-none" data-api-load-error></div>

<dl class="row" data-api-load="@apiUrl">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model</dd>
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10" data-api-field="name">—</dd>
    <dt class="col-sm-2">Correo</dt>
    <dd class="col-sm-10" data-api-field="email">—</dd>
    <dt class="col-sm-2">Activo</dt>
    <dd class="col-sm-10" data-api-field="active">—</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model" class="btn btn-primary">Editar</a>
<a href="@ModuleRoutes.GetWorkspacePath("SUPPLIERS")" class="btn btn-secondary">Volver</a>
