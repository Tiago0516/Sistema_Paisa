@model SistemaPaisa.Application.Features.Suppliers.Commands.CreateSupplier.CreateSupplierCommand

@{
    ViewData["Title"] = "Crear proveedor";
}

<h1 class="h3 mb-3">Crear proveedor</h1>

<form data-api-url="/api/suppliers"
      data-api-redirect="@ModuleRoutes.GetWorkspacePath("SUPPLIERS")">
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span class="text-danger" data-api-error asp-validation-for="Name"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" type="email" />
        <span class="text-danger" data-api-error asp-validation-for="Email"></span>
    </div>
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a href="@ModuleRoutes.GetWorkspacePath("SUPPLIERS")" class="btn btn-secondary">Volver</a>
</form>
