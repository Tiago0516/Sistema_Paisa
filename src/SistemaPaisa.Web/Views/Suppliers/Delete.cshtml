@model int

@{
    ViewData["Title"] = "Eliminar proveedor";
    var apiUrl = $"/api/suppliers/{Model}";
}

<h1 class="h3 mb-3 text-danger">Eliminar proveedor</h1>

<p>¿Está seguro de que desea eliminar este proveedor?</p>

<div class="alert alert-danger d-none" data-api-load-error></div>

<dl class="row" data-api-load="@apiUrl">
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10" data-api-field="name">—</dd>
    <dt class="col-sm-2">Correo</dt>
    <dd class="col-sm-10" data-api-field="email">—</dd>
</dl>

<form data-api-url="@apiUrl"
      data-api-method="DELETE"
      data-api-redirect="@ModuleRoutes.GetWorkspacePath("SUPPLIERS")">
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a href="@ModuleRoutes.GetWorkspacePath("SUPPLIERS")" class="btn btn-secondary">Cancelar</a>
</form>
