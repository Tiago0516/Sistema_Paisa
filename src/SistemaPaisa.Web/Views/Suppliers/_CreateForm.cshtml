@model SistemaPaisa.Application.Features.Suppliers.Commands.CreateSupplier.CreateSupplierCommand

<form method="post"
      class="module-modal-form"
      data-modal-form="true"
      data-api-url="/api/suppliers"
      data-api-reload-grid="true">
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span class="text-danger" data-api-error asp-validation-for="Name"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" type="email" />
        <span class="text-danger" data-api-error asp-validation-for="Email"></span>
    </div>
    <div class="d-flex justify-content-end gap-2 pt-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-module-create">Guardar</button>
    </div>
</form>
