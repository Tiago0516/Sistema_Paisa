@using SistemaPaisa.Application.Common
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Paisa</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="@(User.Identity?.IsAuthenticated == true ? "app-body" : "auth-body")">
@if (User.Identity?.IsAuthenticated == true)
{
    <header class="app-topbar">
        <div class="topbar-left">
            <a class="topbar-brand" href="@ModuleRoutes.GetWorkspacePath("SYSTEM")">
                <span class="brand-icon"><i class="bi bi-geo-alt-fill"></i></span>
                <span class="brand-text">SISTEMA PAISA</span>
            </a>
        </div>
        <div class="topbar-center">
            <div class="topbar-pill topbar-client">
                <i class="bi bi-search"></i>
                <span>@(User.FindFirst(AuthClaimTypes.ClientName)?.Value ?? "Client")</span>
                <i class="bi bi-chevron-down ms-1"></i>
            </div>
        </div>
        <div class="topbar-right">
            <button type="button" class="topbar-icon-btn" title="Notifications">
                <i class="bi bi-bell"></i>
                <span class="badge-dot">0</span>
            </button>
            <div class="dropdown">
                <button class="topbar-pill topbar-user dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-person-circle"></i>
                    <span>@User.Identity?.Name</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark">
                    <li class="dropdown-header">
                        @User.FindFirst(AuthClaimTypes.RoleName)?.Value
                    </li>
                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus me-2"></i>Registrar usuario</a></li>
                    <li><hr class="dropdown-divider" /></li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item">Sign out</button>
                        </form>
                    </li>
                </ul>
            </div>
            <div class="topbar-datetime">
                <div><i class="bi bi-calendar3 me-1"></i><span id="topbarDate"></span></div>
                <div><i class="bi bi-clock me-1"></i><span id="topbarTime"></span></div>
            </div>
        </div>
    </header>

    <div class="app-shell">
        @await Component.InvokeAsync("ModuleSidebar")
        <main class="app-main">
            @RenderBody()
        </main>
    </div>

    <partial name="_ModuleCreateModal" />
}
else
{
    @RenderBody()
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/http-log.js" asp-append-version="true"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/profile-form.js" asp-append-version="true"></script>
@if (User.Identity?.IsAuthenticated == true)
{
    <partial name="_ValidationScriptsPartial" />
}
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
