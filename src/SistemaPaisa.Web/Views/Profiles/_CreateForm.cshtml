@model SistemaPaisa.Application.Features.Profiles.Commands.CreateProfile.CreateProfileCommand

<form asp-controller="Profiles"
      asp-action="Create"
      method="post"
      class="module-modal-form profile-form"
      data-modal-form="true"
      data-actions-url="@Url.Action("ActionsByModule", "Profiles")">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Nombre</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label">Descripción</label>
        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
    </div>
    <div class="mb-3">
        <label class="form-label">Módulos del menú lateral</label>
        <p class="text-muted small mb-2">Seleccione los módulos que verá el usuario con este perfil.</p>
        <partial name="_ProfileModulesCheckboxes" />
    </div>
    <div class="mb-3">
        <label class="form-label">Acciones permitidas</label>
        <p class="text-muted small mb-2">Si no marca ninguna, se habilitan todas las acciones de cada módulo seleccionado.</p>
        <div class="profile-actions-list" data-selected-actions="@string.Join(",", Model.ActionIds)">
            <partial name="_ProfileActionsCheckboxes" />
        </div>
    </div>
    <div class="d-flex justify-content-end gap-2 pt-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-module-create">Guardar</button>
    </div>
</form>
