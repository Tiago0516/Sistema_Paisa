@model SistemaPaisa.Application.DTOs.ProfileDto

@{
    ViewData["Title"] = "Detalle de perfil";
}

<div class="content-card">
    <h1 class="h4 mb-4">@Model.Name</h1>
    <dl class="row">
        <dt class="col-sm-3">Módulo</dt>
        <dd class="col-sm-9">@Model.ModuleName</dd>
        <dt class="col-sm-3">Descripción</dt>
        <dd class="col-sm-9">@Model.Description</dd>
        <dt class="col-sm-3">Acciones permitidas</dt>
        <dd class="col-sm-9">@Model.ActionsSummary</dd>
        <dt class="col-sm-3">Activo</dt>
        <dd class="col-sm-9">@(Model.IsActive ? "Sí" : "No")</dd>
    </dl>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    <a asp-controller="Home" asp-action="Index" asp-route-module="PROFILES" class="btn btn-secondary">Volver</a>
</div>
