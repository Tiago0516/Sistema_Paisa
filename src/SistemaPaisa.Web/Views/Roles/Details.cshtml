@model SistemaPaisa.Application.DTOs.RoleDto

@{
    ViewData["Title"] = "Detalles del rol";
}

<h1 class="h3 mb-3">Detalles del rol</h1>

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Descripción</dt>
    <dd class="col-sm-10">@Model.Description</dd>
    <dt class="col-sm-2">Perfil</dt>
    <dd class="col-sm-10">@Model.ProfileName</dd>
    <dt class="col-sm-2">Cliente</dt>
    <dd class="col-sm-10">@Model.ClientName</dd>
    <dt class="col-sm-2">Activo</dt>
    <dd class="col-sm-10">@(Model.IsActive ? "Sí" : "No")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
<a href="@ModuleRoutes.GetWorkspacePath("ROLES")" class="btn btn-secondary">Volver</a>
