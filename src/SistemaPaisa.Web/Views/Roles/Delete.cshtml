@model SistemaPaisa.Application.DTOs.RoleDto

@{
    ViewData["Title"] = "Eliminar rol";
}

<h1 class="h3 mb-3 text-danger">Eliminar rol</h1>

<p>¿Está seguro de que desea eliminar este rol?</p>

<dl class="row">
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Descripción</dt>
    <dd class="col-sm-10">@Model.Description</dd>
    <dt class="col-sm-2">Perfil</dt>
    <dd class="col-sm-10">@Model.ProfileName</dd>
    <dt class="col-sm-2">Cliente</dt>
    <dd class="col-sm-10">@Model.ClientName</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-controller="Home" asp-action="Index" asp-route-module="ROLES" class="btn btn-secondary">Cancelar</a>
</form>
