@model SistemaPaisa.Application.Features.Roles.Commands.CreateRole.CreateRoleCommand
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    var profiles = ViewBag.Profiles as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
    var clients = ViewBag.Clients as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
}

<form asp-controller="Roles"
      asp-action="Create"
      method="post"
      class="module-modal-form"
      data-modal-form="true">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Nombre</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label">Descripción</label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ProfileId" class="form-label">Perfil</label>
        <select asp-for="ProfileId" asp-items="profiles" class="form-select">
            <option value="">Seleccione un perfil</option>
        </select>
        <span asp-validation-for="ProfileId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ClientId" class="form-label">Cliente</label>
        <select asp-for="ClientId" asp-items="clients" class="form-select">
            <option value="">Seleccione un cliente</option>
        </select>
        <span asp-validation-for="ClientId" class="text-danger"></span>
    </div>
    <div class="d-flex justify-content-end gap-2 pt-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-module-create">Guardar</button>
    </div>
</form>
